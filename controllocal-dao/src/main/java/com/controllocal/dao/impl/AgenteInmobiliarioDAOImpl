package com.controllocal.dao.impl;

import com.controllocal.dao.AgenteInmobiliarioDAO;
import com.controllocal.dao.DAOException;
import com.controllocal.model.usuario.AgenteInmobiliario;

import java.sql.*;
import java.util.ArrayList;
import java.util.List;
import java.util.Optional;

public class AgenteInmobiliarioDAOImpl implements AgenteInmobiliarioDAO {

    private final Connection conn;

    public AgenteInmobiliarioDAOImpl(Connection conn) {
        this.conn = conn;
    }

    @Override
    public Long crear(AgenteInmobiliario agente) {
        String sql = "INSERT INTO agente_inmobiliario " +
                "(codigo_agente, zona_asignada, fecha_ingreso, estado_operativo) " +
                "VALUES (?, ?, ?, ?)";

        try (PreparedStatement ps = conn.prepareStatement(sql, Statement.RETURN_GENERATED_KEYS)) {

            ps.setString(1, agente.getCodigoAgente());
            ps.setString(2, agente.getZonaAsignada());
            ps.setDate(3, Date.valueOf(agente.getFechaIngreso()));
            ps.setString(4, agente.getEstadoOperativo());

            ps.executeUpdate();

            try (ResultSet rs = ps.getGeneratedKeys()) {
                if (rs.next()) return rs.getLong(1);
            }

        } catch (SQLException e) {
            throw new DAOException("Error al crear agente inmobiliario", e);
        }

        return null;
    }

    @Override
    public Optional<AgenteInmobiliario> buscarPorId(Long id) {
        String sql = "SELECT * FROM agente_inmobiliario WHERE id_agente = ?";

        try (PreparedStatement ps = conn.prepareStatement(sql)) {

            ps.setLong(1, id);
            try (ResultSet rs = ps.executeQuery()) {

                if (rs.next()) return Optional.of(mapear(rs));
            }

        } catch (SQLException e) {
            throw new DAOException("Error al buscar agente por ID", e);
        }

        return Optional.empty();
    }

    @Override
    public List<AgenteInmobiliario> listarTodos() {
        List<AgenteInmobiliario> lista = new ArrayList<>();
        String sql = "SELECT * FROM agente_inmobiliario";

        try (Statement st = conn.createStatement();
             ResultSet rs = st.executeQuery(sql)) {

            while (rs.next()) {
                lista.add(mapear(rs));
            }

        } catch (SQLException e) {
            throw new DAOException("Error al listar agentes", e);
        }

        return lista;
    }

    @Override
    public boolean actualizar(AgenteInmobiliario agente) {
        String sql = "UPDATE agente_inmobiliario " +
                "SET codigo_agente = ?, zona_asignada = ?, estado_operativo = ? " +
                "WHERE id_agente = ?";

        try (PreparedStatement ps = conn.prepareStatement(sql)) {

            ps.setString(1, agente.getCodigoAgente());
            ps.setString(2, agente.getZonaAsignada());
            ps.setString(3, agente.getEstadoOperativo());
            ps.setLong(4, agente.getIdAgente());

            return ps.executeUpdate() > 0;

        } catch (SQLException e) {
            throw new DAOException("Error al actualizar agente", e);
        }
    }

    @Override
    public boolean eliminar(Long id) {
        String sql = "DELETE FROM agente_inmobiliario WHERE id_agente = ?";

        try (PreparedStatement ps = conn.prepareStatement(sql)) {

            ps.setLong(1, id);
            return ps.executeUpdate() > 0;

        } catch (SQLException e) {
            throw new DAOException("Error al eliminar agente", e);
        }
    }

    private AgenteInmobiliario mapear(ResultSet rs) throws SQLException {
        AgenteInmobiliario a = new AgenteInmobiliario();

        a.setIdAgente(rs.getLong("id_agente"));
        a.setCodigoAgente(rs.getString("codigo_agente"));
        a.setZonaAsignada(rs.getString("zona_asignada"));
        a.setFechaIngreso(rs.getDate("fecha_ingreso").toLocalDate());
        a.setEstadoOperativo(rs.getString("estado_operativo"));

        return a;
    }
}
